ARG DENO_VERSION=2.7.2
FROM denoland/deno:${DENO_VERSION}

WORKDIR /app

# Copy config files first for better caching
COPY deno.jsonc .
COPY package.json .
COPY vitest.config.deno.ts .

# Install dependencies
RUN deno install

# Copy source and test files
COPY mod.ts .
COPY src/ src/
COPY tests/ tests/
COPY repos/ repos/

# Cache modules
RUN deno cache mod.ts

# Default command - run full test suite
CMD ["deno", "run", "-A", "npm:vitest", "run", "--config", "vitest.config.deno.ts"]
